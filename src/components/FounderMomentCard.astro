---
interface Props {
  quote: string;
  resolution: string;
}

const { quote, resolution } = Astro.props;
---

<div class="rounded-2xl border border-ink/10 bg-white p-6">
  <p class="text-base font-semibold leading-snug text-ink">"{quote}"</p>
  <p class="mt-3 text-sm text-muted">{resolution}</p>
</div>
