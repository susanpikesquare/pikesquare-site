---
// GTM Dimensions Hexagon - shows the 6 core GTM dimensions
---

<div class="w-full flex justify-center">
  <svg viewBox="0 0 600 650" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-2xl">
    <defs>
      <style>
        .dimension-label { font-weight: bold; font-size: 16px; text-anchor: middle; }
        .center-label { font-weight: bold; font-size: 20px; text-anchor: middle; }
        .sub-label { font-size: 12px; text-anchor: middle; fill: #6B7280; }
      </style>
    </defs>

    <!-- Center circle -->
    <circle cx="300" cy="325" r="60" fill="#1F2937" opacity="0.05" stroke="#1F2937" stroke-width="2"/>
    <text x="300" y="330" class="center-label" fill="#1F2937">Go-to-Market</text>

    <!-- Strategy - Top -->
    <circle cx="300" cy="100" r="50" fill="#3B82F6" opacity="0.1" stroke="#3B82F6" stroke-width="2"/>
    <text x="300" y="125" class="dimension-label" fill="#1F2937">Strategy</text>
    <text x="300" y="145" class="sub-label">Vision, ICP, Positioning</text>

    <!-- Motion - Top Right -->
    <circle cx="475" cy="175" r="50" fill="#10B981" opacity="0.1" stroke="#10B981" stroke-width="2"/>
    <text x="475" y="200" class="dimension-label" fill="#1F2937">Motion</text>
    <text x="475" y="220" class="sub-label">Plays, Campaigns</text>

    <!-- Message - Bottom Right -->
    <circle cx="450" cy="475" r="50" fill="#F59E0B" opacity="0.1" stroke="#F59E0B" stroke-width="2"/>
    <text x="450" y="500" class="dimension-label" fill="#1F2937">Message</text>
    <text x="450" y="520" class="sub-label">Value Prop, Positioning</text>

    <!-- Operations - Bottom Left -->
    <circle cx="150" cy="475" r="50" fill="#EF4444" opacity="0.1" stroke="#EF4444" stroke-width="2"/>
    <text x="150" y="500" class="dimension-label" fill="#1F2937">Operations</text>
    <text x="150" y="520" class="sub-label">Tools, Data, Reporting</text>

    <!-- Talent - Top Left -->
    <circle cx="125" cy="175" r="50" fill="#8B5CF6" opacity="0.1" stroke="#8B5CF6" stroke-width="2"/>
    <text x="125" y="200" class="dimension-label" fill="#1F2937">Talent</text>
    <text x="125" y="220" class="sub-label">Hiring, Roles, Teams</text>

    <!-- Process - Center Right (between Strategy and Motion/Message) -->
    <circle cx="475" cy="325" r="50" fill="#06B6D4" opacity="0.1" stroke="#06B6D4" stroke-width="2"/>
    <text x="475" y="330" class="dimension-label" fill="#1F2937">Process</text>
    <text x="475" y="350" class="sub-label">Workflows, SLAs</text>

    <!-- Connection lines from center to each dimension -->
    <line x1="340" y1="375" x2="410" y2="425" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>
    <line x1="340" y1="375" x2="200" y2="425" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>
    <line x1="300" y1="160" x2="300" y2="265" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>
    <line x1="340" y1="275" x2="425" y2="225" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>
    <line x1="340" y1="375" x2="425" y2="325" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>
    <line x1="260" y1="275" x2="175" y2="225" stroke="#D1D5DB" stroke-width="1" stroke-dasharray="5,5"/>

    <!-- Note at bottom -->
    <text x="300" y="610" font-size="13" text-anchor="middle" fill="#6B7280">
      Apply these six dimensions across demand gen, sales, and customer success
    </text>
  </svg>
</div>
