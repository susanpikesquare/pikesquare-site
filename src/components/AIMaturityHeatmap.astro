---
// AI Maturity Heatmap - shows uneven maturity across dimensions
---

<div class="w-full overflow-x-auto">
  <svg viewBox="0 0 1000 500" xmlns="http://www.w3.org/2000/svg" class="w-full min-w-full">
    <!-- Define gradients -->
    <defs>
      <linearGradient id="maturityGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color:#EF4444;stop-opacity:1" />
        <stop offset="33%" style="stop-color:#F59E0B;stop-opacity:1" />
        <stop offset="66%" style="stop-color:#10B981;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#3B82F6;stop-opacity:1" />
      </linearGradient>
    </defs>

    <!-- Title -->
    <text x="50" y="40" font-size="24" font-weight="bold" fill="#1F2937">
      AI Maturity Profile Example
    </text>
    <text x="50" y="65" font-size="14" fill="#6B7280">
      How organizations mature unevenly across dimensions
    </text>

    <!-- Dimension labels and bars -->
    <g>
      <!-- A. Individual Productivity - Level 4 -->
      <text x="50" y="120" font-size="13" font-weight="600" fill="#1F2937">A. Individual Productivity</text>
      <rect x="350" y="105" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="105" width="270" height="20" fill="#3B82F6" rx="4"/>
      <text x="630" y="122" font-size="12" font-weight="600" fill="#1F2937">Level 4</text>

      <!-- B. Team Enablement - Level 2 -->
      <text x="50" y="165" font-size="13" font-weight="600" fill="#1F2937">B. Team Enablement</text>
      <rect x="350" y="150" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="150" width="90" height="20" fill="#F59E0B" rx="4"/>
      <text x="630" y="167" font-size="12" font-weight="600" fill="#1F2937">Level 2</text>

      <!-- C. Workflow Automation - Level 3 -->
      <text x="50" y="210" font-size="13" font-weight="600" fill="#1F2937">C. Workflow Automation</text>
      <rect x="350" y="195" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="195" width="180" height="20" fill="#10B981" rx="4"/>
      <text x="630" y="212" font-size="12" font-weight="600" fill="#1F2937">Level 3</text>

      <!-- D. Operational Intelligence - Level 1 -->
      <text x="50" y="255" font-size="13" font-weight="600" fill="#1F2937">D. Operational Intelligence</text>
      <rect x="350" y="240" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="240" width="45" height="20" fill="#EF4444" rx="4"/>
      <text x="630" y="257" font-size="12" font-weight="600" fill="#1F2937">Level 1</text>

      <!-- E. Decision Support - Level 1 -->
      <text x="50" y="300" font-size="13" font-weight="600" fill="#1F2937">E. Decision Support</text>
      <rect x="350" y="285" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="285" width="45" height="20" fill="#EF4444" rx="4"/>
      <text x="630" y="302" font-size="12" font-weight="600" fill="#1F2937">Level 1</text>

      <!-- F. Customer Experience - Level 2 -->
      <text x="50" y="345" font-size="13" font-weight="600" fill="#1F2937">F. Customer Experience</text>
      <rect x="350" y="330" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="330" width="90" height="20" fill="#F59E0B" rx="4"/>
      <text x="630" y="347" font-size="12" font-weight="600" fill="#1F2937">Level 2</text>

      <!-- G. Operating Model Transformation - Level 1 -->
      <text x="50" y="390" font-size="13" font-weight="600" fill="#1F2937">G. Operating Model Transform</text>
      <rect x="350" y="375" width="360" height="20" fill="#E5E7EB" rx="4"/>
      <rect x="350" y="375" width="45" height="20" fill="#EF4444" rx="4"/>
      <text x="630" y="392" font-size="12" font-weight="600" fill="#1F2937">Level 1</text>
    </g>

    <!-- Legend at bottom -->
    <g>
      <rect x="50" y="430" width="15" height="15" fill="#EF4444"/>
      <text x="70" y="442" font-size="12" fill="#6B7280">Level 1: Experimental</text>

      <rect x="270" y="430" width="15" height="15" fill="#F59E0B"/>
      <text x="290" y="442" font-size="12" fill="#6B7280">Level 2: Emerging</text>

      <rect x="490" y="430" width="15" height="15" fill="#10B981"/>
      <text x="510" y="442" font-size="12" fill="#6B7280">Level 3-4: Operationalized/Integrated</text>

      <rect x="820" y="430" width="15" height="15" fill="#3B82F6"/>
      <text x="840" y="442" font-size="12" fill="#6B7280">Level 5-6: Advanced</text>
    </g>
  </svg>
</div>
