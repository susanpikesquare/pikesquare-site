---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { SCHEDULING_URL } from '../lib/site';

const pillars = [
  {
    title: 'Strategy',
    description: 'Which customers matter most, and how to position yourself to win them. This is the foundation everything else sits on.',
  },
  {
    title: 'Motion',
    description: 'How you actually acquire customers. What channels work, how deals flow, how you keep them. Get this right before you scale.',
  },
  {
    title: 'Message',
    description: 'One message your sales and marketing teams can actually use without constantly tweaking it. Consistent, repeatable, coherent.',
  },
  {
    title: 'Process',
    description: 'A repeatable system your whole team can execute. Clear processes mean better execution and less heroics.',
  },
  {
    title: 'Talent',
    description: 'The right people in the right roles with the right incentives. Building and running the team that makes this work.',
  },
  {
    title: 'Operations',
    description: 'Systems, data, and reporting that actually give you clarity. Most teams have the tools. They just need to use them right.',
  },
];

const moments = [
  {
    quote: "We're entering scale-up mode and the GTM playbook hasn't caught up.",
    resolution: 'Fractional GTM leadership to redesign motion, messaging, and operations before it breaks.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Team scaling rapidly',
  },
  {
    quote: 'Our new revenue leader is in seat — I want them to win.',
    resolution: 'Advisory retainer that pattern-matches the hard GTM decisions: market fit, playbooks, hiring.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Leadership mentoring',
  },
  {
    quote: "Our teams are experimenting with AI but we don't have an adoption strategy.",
    resolution: 'AI Stack Audit + GTM Adoption Plan: where AI moves the needle across demand gen, sales, CS.',
    image: 'https://images.unsplash.com/photo-1677442d019dccb08d0bd0b65c9fd12c33b60080?w=600&h=400&fit=crop',
    alt: 'AI tools and strategy',
  },
  {
    quote: "Our CS onboarding works at $5M but we're hitting $20M and it's broken.",
    resolution: 'CS Operating Model Redesign: service tiering, standardization, automation readiness.',
    image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&h=400&fit=crop',
    alt: 'Business growth and scale',
  },
  {
    quote: 'We need to build our demand gen motion from scratch.',
    resolution: 'GTM strategy, positioning, target buyer design, campaign playbooks, and AI integration.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Demand generation strategy',
  },
  {
    quote: "Our sales team is inconsistent and we don't have a scalable process.",
    resolution: 'Sales process build, pitch deck, playbooks, training, and AI-powered execution tools.',
    image: 'https://images.unsplash.com/photo-1505373877957-f4161e1f0d25?w=600&h=400&fit=crop',
    alt: 'Sales excellence and scale',
  },
];
---

<BaseLayout title="PikeSquare — Senior GTM operators for startups and scale-ups">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 pb-24 pt-20 md:pt-28">
      <h1 class="max-w-3xl font-display text-4xl font-bold tracking-tight text-deep md:text-6xl md:leading-[1.05]">
        Senior GTM operators for startups and scale-ups.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted md:text-xl">
        Experienced GTM operators. External perspective or embedded leadership — shaped to what you need.
      </p>
      <div class="mt-10 flex flex-col items-start gap-4 md:flex-row md:items-center">
        <CTAButton />
        <a
          href="/services"
          class="text-base font-semibold text-deep underline-offset-4 hover:underline"
        >
          See what we do →
        </a>
      </div>
    </div>
  </section>

  <!-- Moments Carousel (moved above pillars) -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Moments we're built for
      </p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-deep">
        If one of these moments describes your situation, let's talk.
      </h2>

      <div class="mt-10 grid gap-8 md:grid-cols-2 items-center">
        <!-- Carousel Image - changes with each moment -->
        <div class="rounded-2xl overflow-hidden order-2 md:order-1">
          <img
            id="carousel-image"
            src={moments[0].image}
            alt={moments[0].alt}
            class="w-full h-auto transition-opacity duration-500"
          />
        </div>

        <!-- Carousel Content -->
        <div class="rounded-2xl border border-ink/10 bg-bg p-8 order-1 md:order-2">
          <div id="moments-carousel" class="space-y-4">
            {moments.map((moment, index) => (
              <div
                class={`moment-slide transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 hidden'}`}
                data-index={index}
              >
                <blockquote class="text-lg font-semibold text-deep italic mb-3">
                  "{moment.quote}"
                </blockquote>
                <p class="text-sm text-muted">
                  <span class="font-semibold text-ink">We help with:</span> {moment.resolution}
                </p>
              </div>
            ))}
          </div>

          <!-- Carousel indicators -->
          <div class="mt-6 flex gap-2 justify-center">
            {moments.map((_, index) => (
              <button
                class={`w-2 h-2 rounded-full transition ${index === 0 ? 'bg-accent' : 'bg-ink/20'}`}
                data-slide={index}
                aria-label={`Go to moment ${index + 1}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GTM Pillars -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Six dimensions of GTM
      </p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        We help you get right across all of it.
      </h2>

      <!-- Detailed cards -->
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {pillars.map((pillar) => (
          <article class="rounded-2xl border border-ink/10 bg-bg p-6">
            <h3 class="font-display text-xl font-bold text-deep">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink">{pillar.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Section -->
  <section class="border-b border-ink/10 bg-accent/5">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        AI as a Core GTM Capability
      </p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold tracking-tight text-deep md:text-4xl">
        AI is now essential. But most teams don't know where to start.
      </h2>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        We help GTM teams adopt AI strategically—not just experimenting, but embedding it across demand gen, sales, and customer success. From auditing your AI stack to building your adoption maturity across seven key dimensions, we help you compete at the speed of AI.
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-2xl border border-accent/20 bg-white p-6">
          <h3 class="font-display text-lg font-bold text-deep">AI Stack Audit</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted">Where's AI working? Where are you wasting budget? What's your 30/60/90 adoption plan?</p>
        </article>
        <article class="rounded-2xl border border-accent/20 bg-white p-6">
          <h3 class="font-display text-lg font-bold text-deep">GTM AI Adoption</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted">Build AI maturity across demand gen, sales, and CS. AI-powered workflows that scale your team.</p>
        </article>
        <article class="rounded-2xl border border-accent/20 bg-white p-6">
          <h3 class="font-display text-lg font-bold text-deep">Team Enablement</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted">Train your teams to leverage AI as part of their daily work. Build new playbooks, new workflows, new models.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep md:text-4xl">
        Let's talk about your GTM and AI strategy.
      </h2>
      <p class="mt-4 text-lg text-muted">
        A conversation about where you stand strategically across GTM and AI. We'll tell you if we can help — or point you somewhere that can.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href={SCHEDULING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-deep px-7 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-accent hover:text-white"
        >
          Book a meeting
        </a>
      </div>
      <p class="mt-6 text-sm text-muted">
        Not sure where to start? <a href="/assessments" class="font-semibold text-deep underline-offset-4 hover:underline">Take the GTM assessment</a> or <a href="/ai-diagnostic" class="font-semibold text-deep underline-offset-4 hover:underline">measure your AI maturity.</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Moment data with images
  const momentData = [
    { image: 'https://images.unsplash.com/photo-1758873272809-7947b9a73fe5?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'Team collaborating on project' },
    { image: 'https://images.unsplash.com/photo-1758611972589-0012481178f9?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'Colleagues collaborating at desk' },
    { image: 'https://images.unsplash.com/photo-1677442135703-1787eea5ce01?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'AI circuit board with brain' },
    { image: 'https://images.unsplash.com/photo-1748609160056-7b95f30041f0?q=80&w=1931&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'Financial data analysis' },
    { image: 'https://images.unsplash.com/photo-1758691736451-6937303cc06f?q=80&w=1932&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'Man presenting to colleagues' },
    { image: 'https://images.unsplash.com/photo-1575029644286-efb9039cac46?q=80&w=1738&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', alt: 'Professional presenting' }
  ];

  // Auto-rotating moments carousel
  let currentSlide = 0;
  const slides = document.querySelectorAll('.moment-slide');
  const indicators = document.querySelectorAll('[data-slide]');
  const carouselImage = document.getElementById('carousel-image');

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === index);
      slide.classList.toggle('opacity-0', i !== index);
      slide.classList.toggle('hidden', i !== index);
    });

    indicators.forEach((indicator, i) => {
      indicator.classList.toggle('bg-accent', i === index);
      indicator.classList.toggle('bg-ink/20', i !== index);
    });

    // Update image to match current slide
    if (carouselImage && momentData[index]) {
      carouselImage.src = momentData[index].image;
      carouselImage.alt = momentData[index].alt;
    }
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    showSlide(currentSlide);
  }

  // Auto-rotate every 7 seconds
  setInterval(nextSlide, 7000);

  // Manual navigation
  indicators.forEach((indicator) => {
    indicator.addEventListener('click', (e) => {
      const target = e.target;
      const slideStr = target.getAttribute('data-slide');
      if (slideStr !== null) {
        currentSlide = parseInt(slideStr, 10);
        showSlide(currentSlide);
      }
    });
  });
</script>
