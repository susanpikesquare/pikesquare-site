---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { SCHEDULING_URL } from '../lib/site';

const pillars = [
  {
    title: 'Go-to-Market Strategy',
    description: 'Focus on the right customers and market positioning. We help you cut through the noise and pick what actually matters.',
  },
  {
    title: 'Go-to-Market Motion',
    description: 'Design how you acquire customers, what channels work, how deals move, and how you retain them. Get the motion right before you try to scale it.',
  },
  {
    title: 'Go-to-Market Message',
    description: 'Build a message your sales and marketing teams will actually use — consistently, repeatably, and without having to customize it to death.',
  },
  {
    title: 'Go-to-Market Process',
    description: 'Create a repeatable process your whole team can execute. When the process is clear, execution gets better and you reduce the heroics.',
  },
  {
    title: 'Go-to-Market Talent',
    description: 'Build the right organization, hire the right people, design the incentives, and get them to perform. We help you get the team right.',
  },
  {
    title: 'Go-to-Market Operations',
    description: 'Implement the systems, data, and reporting that actually improve outcomes. Most teams have the tools — they just need the right operating system.',
  },
];

const moments = [
  {
    quote: "We're entering scale-up mode and the GTM playbook hasn't caught up.",
    resolution: 'Fractional leadership or a project to redesign the motion before it breaks.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Team scaling rapidly',
  },
  {
    quote: 'Our new revenue leader is in seat — I want them to win.',
    resolution: 'Advisory retainer that pattern-matches the hard moments: deals, hires, the board.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Leadership mentoring',
  },
  {
    quote: "Half our team's already using AI — and we have no idea what's working.",
    resolution: 'A 2-week AI Stack Audit: where AI moves the needle, build vs. buy, 30/60/90 plan.',
    image: 'https://images.unsplash.com/photo-1677442d019dccb08d0bd0b65c9fd12c33b60080?w=600&h=400&fit=crop',
    alt: 'AI tools and data confusion',
  },
  {
    quote: "Renewals are coming and our CS team can't see risk in time.",
    resolution: 'CS risk and renewal plays — risk definitions, signals, team structure.',
    image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&h=400&fit=crop',
    alt: 'Business risk and pressure',
  },
  {
    quote: 'Our pitch deck is a Frankenstein and reps are losing the room.',
    resolution: 'A sales pitch deck build: story architecture, modular variants, rep enablement.',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop',
    alt: 'Meeting presentation',
  },
  {
    quote: 'Our SKO is in eight weeks and the deck is still empty.',
    resolution: 'A turnkey sales kickoff — content, training, exercises, venue, keynote.',
    image: 'https://images.unsplash.com/photo-1505373877957-f4161e1f0d25?w=600&h=400&fit=crop',
    alt: 'Time pressure and deadline',
  },
];
---

<BaseLayout title="PikeSquare — Senior GTM operators for startups and scale-ups">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 pb-24 pt-20 md:pt-28">
      <h1 class="max-w-3xl font-display text-4xl font-bold tracking-tight text-deep md:text-6xl md:leading-[1.05]">
        Senior GTM operators for startups and scale-ups.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted md:text-xl">
        We embed with your revenue team. Strategy, execution, and AI — all from someone who's held the role.
      </p>
      <div class="mt-10 flex flex-col items-start gap-4 md:flex-row md:items-center">
        <CTAButton />
        <a
          href="/services"
          class="text-base font-semibold text-deep underline-offset-4 hover:underline"
        >
          See what we do →
        </a>
      </div>
    </div>
  </section>

  <!-- Moments Carousel (moved above pillars) -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Moments we're built for
      </p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-deep">
        If one of these sounds like your quarter, let's talk.
      </h2>

      <div class="mt-10 grid gap-8 md:grid-cols-2 items-center">
        <!-- Carousel Image - changes with each moment -->
        <div class="rounded-2xl overflow-hidden order-2 md:order-1">
          <img
            id="carousel-image"
            src={moments[0].image}
            alt={moments[0].alt}
            class="w-full h-auto transition-opacity duration-500"
          />
        </div>

        <!-- Carousel Content -->
        <div class="rounded-2xl border border-ink/10 bg-bg p-8 order-1 md:order-2">
          <div id="moments-carousel" class="space-y-4">
            {moments.map((moment, index) => (
              <div
                class={`moment-slide transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 hidden'}`}
                data-index={index}
                data-image={moment.image}
                data-alt={moment.alt}
              >
                <blockquote class="text-lg font-semibold text-deep italic mb-3">
                  "{moment.quote}"
                </blockquote>
                <p class="text-sm text-muted">
                  <span class="font-semibold text-ink">We help with:</span> {moment.resolution}
                </p>
              </div>
            ))}
          </div>

          <!-- Carousel indicators -->
          <div class="mt-6 flex gap-2 justify-center">
            {moments.map((_, index) => (
              <button
                class={`w-2 h-2 rounded-full transition ${index === 0 ? 'bg-accent' : 'bg-ink/20'}`}
                data-slide={index}
                aria-label={`Go to moment ${index + 1}`}
              />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GTM Pillars -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">
        Six dimensions of GTM
      </p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        We help you get right across all of it.
      </h2>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {pillars.map((pillar) => (
          <article class="rounded-2xl border border-ink/10 bg-bg p-6">
            <h3 class="font-display text-xl font-bold text-deep">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink">{pillar.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep md:text-4xl">
        Let's talk about your quarter.
      </h2>
      <p class="mt-4 text-lg text-muted">
        30 minutes. No pitch. Just a conversation about where you are and where you want to go.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href={SCHEDULING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-deep px-7 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-accent hover:text-white"
        >
          Book a meeting
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Auto-rotating moments carousel
  let currentSlide = 0;
  const slides = document.querySelectorAll('.moment-slide');
  const indicators = document.querySelectorAll('[data-slide]');
  const carouselImage = document.getElementById('carousel-image');

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === index);
      slide.classList.toggle('opacity-0', i !== index);
      slide.classList.toggle('hidden', i !== index);
    });

    indicators.forEach((indicator, i) => {
      indicator.classList.toggle('bg-accent', i === index);
      indicator.classList.toggle('bg-ink/20', i !== index);
    });

    // Update image to match current slide
    if (carouselImage && slides[index]) {
      const imageUrl = slides[index].getAttribute('data-image');
      const imageAlt = slides[index].getAttribute('data-alt');
      if (imageUrl) {
        carouselImage.src = imageUrl;
      }
      if (imageAlt) {
        carouselImage.alt = imageAlt;
      }
    }
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    showSlide(currentSlide);
  }

  // Auto-rotate every 7 seconds
  setInterval(nextSlide, 7000);

  // Manual navigation
  indicators.forEach((indicator) => {
    indicator.addEventListener('click', (e) => {
      const target = e.target;
      const slideStr = target.getAttribute('data-slide');
      if (slideStr !== null) {
        currentSlide = parseInt(slideStr, 10);
        showSlide(currentSlide);
      }
    });
  });
</script>
