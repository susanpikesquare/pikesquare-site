---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SCHEDULING_URL } from '../../lib/site';

// Six engagement categories aligned with GTM + AI
const categories = [
  {
    title: 'Advisory & Fractional Leadership',
    blurb: 'We work alongside you as GTM leader — advising on strategy, decisions, or stepping into interim leadership roles. You get someone who has actually held the roles.',
    shape: 'Retainer or fractional seat',
    items: [
      { label: 'GTM Advisory Retainer' },
      { label: 'Fractional GTM, Sales, CS, or RevOps leadership' },
      { label: 'Executive pattern-matching and board prep' },
    ],
  },
  {
    title: 'Strategy & Diagnostics',
    blurb: 'We audit what\'s working and what\'s not across your GTM machine—demand gen, sales, CS, and operations. You get a clear diagnosis and a roadmap to fix it.',
    shape: 'Fixed-scope engagements',
    items: [
      { label: 'GTM Execution Health Diagnostic' },
      { label: 'AI Adoption & Maturity Assessment' },
      { label: 'CS Operating Model Assessment' },
      { label: 'Positioning & ICP Redesign' },
      { label: 'GTM Readiness for Fundraising' },
    ],
  },
  {
    title: 'Customer Success & Scaling',
    blurb: 'Design CS operating models that evolve as you scale. Build white-glove service at early stage, then transition to standardized, AI-enabled models at $50M+.',
    shape: 'Project-based or retainer',
    items: [
      { label: 'CS Operating Model Design' },
      { label: 'Onboarding Playbook & Process Build' },
      { label: 'Service Tiering Strategy' },
      { label: 'CS Automation & Workflow Design' },
      { label: 'CS Metrics, SLAs, and Health Scoring' },
    ],
  },
  {
    title: 'AI for GTM',
    blurb: 'Embed AI across your GTM machine—demand gen, sales, and CS. We help with stack audits, operationalization, team enablement, and ongoing adoption.',
    shape: 'Audit, build, enable, or advise',
    items: [
      { label: 'AI Stack Audit & Roadmap' },
      { label: 'AI Adoption Strategy & Operationalization' },
      { label: 'AI Workflow Build & Automation' },
      { label: 'AI Enablement & Team Training' },
      { label: 'AI-Powered Decision Support Systems' },
    ],
  },
  {
    title: 'Programs & Builds',
    blurb: 'Sales kickoffs, pitch decks, messaging, processes. We build them with your team so you can actually run them.',
    shape: 'Project-based',
    items: [
      { label: 'Sales Kickoff & SKO Program' },
      { label: 'Sales Pitch Deck Build' },
      { label: 'GTM Messaging & Positioning' },
      { label: 'Sales Process & Playbook Design' },
      { label: 'Demand Gen Strategy & Campaign Build' },
    ],
  },
  {
    title: 'Speaking & Workshops',
    blurb: 'Keynotes on GTM and AI. Leadership workshops to think through strategy together. Panel facilitation.',
    shape: 'Per-engagement, prep included',
    items: [
      { label: 'GTM and AI keynotes' },
      { label: 'Executive strategy workshops' },
      { label: 'GTM Scaling workshops' },
      { label: 'Panel and fireside facilitation' },
    ],
  },
];
---

<BaseLayout title="Services — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 pb-16 pt-20">
      <h1 class="font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        Pick the engagement that fits the moment.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        Six ways to engage — each with examples of the work we typically take on. If your moment looks different, we can probably shape something for it. The shortest path is a 30-minute conversation.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-6 md:grid-cols-2">
        {
          categories.map((c) => (
            <article class="flex h-full flex-col rounded-2xl border border-ink/10 bg-bg p-7">
              <h2 class="font-display text-2xl font-bold text-deep">{c.title}</h2>
              <p class="mt-3 text-base leading-relaxed text-ink">{c.blurb}</p>
              <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-muted">Shape</p>
              <p class="mt-1 text-sm text-muted">{c.shape}</p>
              <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-muted">Examples</p>
              <ul class="mt-2 space-y-2">
                {c.items.map((it) => (
                  <li class="flex gap-3 text-sm">
                    <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 flex-none bg-accent" />
                    <span class="text-deep">{it.label}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
      <p class="mt-12 text-base text-muted">
        Not sure which fits? <a href={SCHEDULING_URL} target="_blank" rel="noopener noreferrer" class="font-semibold text-deep underline-offset-4 hover:underline">Book a 30-minute meeting</a> and we'll tell you — and if we're not the right fit, we'll point you somewhere better.
      </p>
    </div>
  </section>

  <!-- Closing CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
