---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SCHEDULING_URL } from '../../lib/site';

// Five top-level engagement categories. Each has a one-line frame, an
// engagement shape, and a list of concrete examples — most of which link
// to a detail page.
const categories = [
  {
    title: 'Advisory & Fractional Leadership',
    blurb: 'We work alongside you as GTM leader — strategy, decisions, or interim ownership. You get someone who has actually held the role.',
    shape: 'Retainer or fractional seat',
    items: [
      { label: 'Advisory Retainer (Susan or Steve)' },
      { label: 'Fractional GTM Leadership (CRO, VP Sales, VP CS, RevOps)' },
      { label: 'CEO / board pattern-matching' },
    ],
  },
  {
    title: 'Strategy & Diagnostics',
    blurb: "We dig into what's working and what's not. You get a clear, realistic picture and a plan to fix it.",
    shape: 'Fixed scope',
    items: [
      { label: 'GTM Diagnostics & Plan' },
      { label: 'Scale-up readiness review' },
      { label: 'Board / fundraise GTM prep' },
      { label: 'ICP and target-buyer redesign' },
    ],
  },
  {
    title: 'Programs & Builds',
    blurb: 'Sales kickoffs, pitch decks, enablement, processes — we build them with your team so you can actually run them.',
    shape: 'Project-based',
    items: [
      { label: 'Sales Kickoffs & Enablement Programs' },
      { label: 'Sales Pitch Deck Build' },
      { label: 'RevOps & GTM Effectiveness' },
      { label: 'Custom app builds' },
    ],
  },
  {
    title: 'Quick-turn Projects',
    blurb: 'Specific work you need done — pitch deck refresh, messaging audit, tools review, training. Fast turnaround, fixed price.',
    shape: 'Async, fixed price',
    items: [
      { label: 'Pitch Deck Refresh' },
      { label: 'Messaging Audit' },
      { label: 'Data Sheet / One-Pager' },
      { label: 'GTM Tools Audit' },
      { label: 'Training Module' },
    ],
  },
  {
    title: 'AI Services',
    blurb: 'Put AI to work on your revenue problems — dig into the data you already have, build custom tools, train your team to use them.',
    shape: 'Audit, build, train, or speak',
    items: [
      { label: 'AI Stack Audit' },
      { label: 'AI Data Surfacing' },
      { label: 'AI Enablement & Training' },
      { label: 'AI for Sales Kickoffs' },
      { label: 'AI-Augmented Sales Pitch Decks' },
    ],
  },
  {
    title: 'Speaking & Workshops',
    blurb: 'Keynotes at your sales kickoff or conference. Workshops for your leadership team to work through GTM strategy together.',
    shape: 'Per-engagement, prep + delivery included',
    items: [
      { label: 'Sales kickoff and conference keynotes' },
      { label: 'AI in the modern revenue org (keynote)' },
      { label: 'Executive workshops on GTM strategy' },
      { label: 'Panel and fireside facilitation' },
    ],
  },
];
---

<BaseLayout title="Services — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 pb-16 pt-20">
      <h1 class="font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        Pick the engagement that fits the moment.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        Six ways to engage — each with examples of the work we typically take on. If your moment looks different, we can probably shape something for it. The shortest path is a 30-minute conversation.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <div class="grid gap-6 md:grid-cols-2">
        {
          categories.map((c) => (
            <article class="flex h-full flex-col rounded-2xl border border-ink/10 bg-bg p-7">
              <h2 class="font-display text-2xl font-bold text-deep">{c.title}</h2>
              <p class="mt-3 text-base leading-relaxed text-ink">{c.blurb}</p>
              <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-muted">Shape</p>
              <p class="mt-1 text-sm text-muted">{c.shape}</p>
              <p class="mt-5 text-xs font-semibold uppercase tracking-wider text-muted">Examples</p>
              <ul class="mt-2 space-y-2">
                {c.items.map((it) => (
                  <li class="flex gap-3 text-sm">
                    <span aria-hidden="true" class="mt-2 inline-block h-1.5 w-1.5 flex-none bg-accent" />
                    <span class="text-deep">{it.label}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
      <p class="mt-12 text-base text-muted">
        Not sure which fits? <a href={SCHEDULING_URL} target="_blank" rel="noopener noreferrer" class="font-semibold text-deep underline-offset-4 hover:underline">Book a 30-minute meeting</a> and we'll tell you — and if we're not the right fit, we'll point you somewhere better.
      </p>
    </div>
  </section>

  <!-- Closing CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
