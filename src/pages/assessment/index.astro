---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SCHEDULING_URL } from '../../lib/site';

// Six GTM pillars — must stay in sync with the home-page pillars and services framing.
// Each pillar has a brief, four maturity-stage descriptors, and a list of services
// PikeSquare offers when this pillar is the gap. Stage descriptors are short and
// concrete on purpose — vague descriptors make the assessment feel like a quiz.
const pillars = [
  {
    key: 'strategy',
    title: 'Strategy',
    blurb: 'Right customers, right buyers, right stage of growth.',
    stages: [
      'No clear ICP — we sell to whoever shows up.',
      'ICP exists but the team doesn\'t use it consistently.',
      'ICP is documented and most pipeline reflects it.',
      'ICP, target buyer, and 90-day plan are sharp and current.',
    ],
    why: 'Without clarity on who you\'re selling to, everything else — your message, your sales motion, your hiring — optimizes for the wrong thing.',
    gapImpact: 'When strategy is unclear, your team wastes energy chasing the wrong deals. Reps get frustrated, win rates drop, and you scale the wrong motion.',
    services: [
      { label: 'GTM Diagnostics & Plan', href: '/services/diagnostics' },
      { label: 'Advisory Retainer', href: '/services/advisory' },
    ],
  },
  {
    key: 'motion',
    title: 'Motion',
    blurb: 'How we acquire, progress, and grow customers.',
    stages: [
      'Acquisition and renewal motions are ad-hoc.',
      'A motion exists for one of {acquire, expand, renew}, not all.',
      'Motions are defined, run, and reviewed quarterly.',
      'Motions are tuned, instrumented, and predictable.',
    ],
    why: 'A repeatable motion is what separates scaling from chaos. Without it, you\'re relying on individual heroics instead of a system.',
    gapImpact: 'Without a clear motion, you can\'t forecast. You can\'t hire. You can\'t coach reps. Every quarter is a surprise, and you\'re always one key person away from missing plan.',
    services: [
      { label: 'Fractional GTM Leadership', href: '/services/fractional-leadership' },
      { label: 'RevOps & GTM Effectiveness', href: '/services/revops' },
    ],
  },
  {
    key: 'message',
    title: 'Message',
    blurb: 'A repeatable story the team can actually tell.',
    stages: [
      'Every rep tells a different version of the story.',
      'A pitch deck exists but reps go off-script.',
      'A consistent narrative is in market and reps stick to it.',
      'Modular variants by persona and vertical, refreshed regularly.',
    ],
    why: 'Reps sell best when they believe the story and can tell it naturally. An inconsistent message confuses buyers and makes your brand feel fractured.',
    gapImpact: 'Reps lose deals because they\'re all saying different things. Buyers get different value props on different calls. Your positioning gets watered down.',
    services: [
      { label: 'Sales Pitch Deck Build', href: '/services' },
      { label: 'AI-Augmented Pitch Decks', href: '/services' },
    ],
  },
  {
    key: 'process',
    title: 'Process',
    blurb: 'Repeatable rituals — forecast, deal review, pipeline.',
    stages: [
      'No reliable forecast or deal-review cadence.',
      'A cadence exists but accuracy is inconsistent.',
      'Forecast within ±10% and deal reviews are productive.',
      'Discipline is a competitive advantage — board-ready every month.',
    ],
    why: 'Process is what turns a sales team into a revenue machine. It\'s the rhythm that forces hard conversations, surfaces problems early, and builds accountability.',
    gapImpact: 'Without reliable process, you can\'t forecast. You surprise the board. You miss the patterns that would let you course-correct early.',
    services: [
      { label: 'RevOps & GTM Effectiveness', href: '/services' },
      { label: 'Fractional GTM Leadership', href: '/services' },
    ],
  },
  {
    key: 'talent',
    title: 'Talent',
    blurb: 'Org design, hiring, comp, and enablement.',
    stages: [
      'Org is improvised; new hires ramp slowly or churn.',
      'Roles are defined but enablement is light.',
      'Onboarding and ongoing enablement are working.',
      'Talent system is a hiring magnet and ramp is fast.',
    ],
    why: 'Your team amplifies or defeats everything else. A weak talent system means constant churn, slow ramps, and good people getting frustrated.',
    gapImpact: 'You lose institutional knowledge when people churn. New hires take months to ramp. Your best people leave because the org is too chaotic to operate in.',
    services: [
      { label: 'Sales Kickoffs & Enablement', href: '/services' },
      { label: 'AI Enablement & Training', href: '/services' },
    ],
  },
  {
    key: 'operations',
    title: 'Operations',
    blurb: 'Systems, data, and AI that improve outcomes.',
    stages: [
      'CRM data is messy; dashboards aren\'t trusted.',
      'Some dashboards exist; data quality is hit-or-miss.',
      'Dashboards are trusted and used in operating rituals.',
      'AI surfaces insights from existing systems; team acts on them.',
    ],
    why: 'You can\'t improve what you don\'t measure. Ops is the nervous system that tells you what\'s actually happening versus what you think is happening.',
    gapImpact: 'Bad data leads to bad decisions. You optimize the wrong things. Reps don\'t trust the CRM. You miss early signals that deals are at risk.',
    services: [
      { label: 'AI Stack Audit', href: '/services' },
      { label: 'AI Data Surfacing', href: '/services' },
    ],
  },
];

// JSON-encoded for the client-side script. Astro renders this once at build time.
const pillarsJson = JSON.stringify(pillars);
---

<BaseLayout title="GTM Readiness Assessment — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Free assessment</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        Where's your GTM breaking down?
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        Rate yourself on six core GTM dimensions. We'll show you where you stand, where you're trying to go, and which gaps are holding you back the most.
      </p>
      <p class="mt-4 max-w-2xl text-sm text-muted">
        Takes 5 minutes. No email required for results. Want the full report delivered? That's optional.
      </p>
    </div>
  </section>

  <!-- Assessment form -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <form id="assessment-form" class="space-y-10" novalidate>
        {
          pillars.map((p, idx) => (
            <fieldset class="rounded-2xl border border-ink/10 bg-bg p-7" data-pillar={p.key}>
              <legend class="px-3 text-xs font-semibold uppercase tracking-wider text-accent">
                Pillar {idx + 1} of 6
              </legend>
              <h2 class="font-display text-2xl font-bold text-deep">{p.title}</h2>
              <p class="mt-2 text-base text-ink">{p.blurb}</p>

              <p class="mt-6 text-xs font-semibold uppercase tracking-wider text-muted">
                Maturity stages
              </p>
              <ol class="mt-2 space-y-1 text-sm text-muted">
                {p.stages.map((s, i) => (
                  <li>
                    <span class="font-semibold text-deep">{i + 1}.</span> {s}
                  </li>
                ))}
              </ol>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-muted">
                    Where you are today
                  </p>
                  <div class="mt-3 flex gap-2" role="radiogroup" aria-label={`${p.title}: current state`}>
                    {[1, 2, 3, 4].map((n) => (
                      <label class="group flex-1 cursor-pointer">
                        <input
                          type="radio"
                          name={`${p.key}-current`}
                          value={n}
                          class="peer sr-only"
                          required
                        />
                        <span
                          class="flex h-12 items-center justify-center rounded-lg border border-ink/15 bg-white text-base font-semibold text-ink transition group-hover:border-deep peer-checked:border-deep peer-checked:bg-deep peer-checked:text-white"
                        >
                          {n}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-muted">
                    Where you want to be in 12 months
                  </p>
                  <div class="mt-3 flex gap-2" role="radiogroup" aria-label={`${p.title}: target state`}>
                    {[1, 2, 3, 4].map((n) => (
                      <label class="group flex-1 cursor-pointer">
                        <input
                          type="radio"
                          name={`${p.key}-target`}
                          value={n}
                          class="peer sr-only"
                          required
                        />
                        <span
                          class="flex h-12 items-center justify-center rounded-lg border border-ink/15 bg-white text-base font-semibold text-ink transition group-hover:border-accent peer-checked:border-accent peer-checked:bg-accent peer-checked:text-white"
                        >
                          {n}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </fieldset>
          ))
        }

        <div id="form-error" class="hidden rounded-lg border border-rust/30 bg-rust/5 p-4 text-sm text-rust">
          Please answer every question — there's a row that's still blank.
        </div>

        <div class="flex flex-col items-start gap-4 md:flex-row md:items-center">
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-deep px-7 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-accent"
          >
            See my results
          </button>
          <button
            type="reset"
            class="text-sm font-semibold text-muted underline-offset-4 hover:text-ink hover:underline"
          >
            Start over
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Results (hidden until submit) -->
  <section id="results" class="hidden border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Your results</p>
      <h2 id="results-headline" class="mt-3 font-display text-3xl font-bold tracking-tight text-deep md:text-4xl">
        <!-- filled by JS -->
      </h2>
      <p id="results-summary" class="mt-4 max-w-2xl text-lg text-muted">
        <!-- filled by JS -->
      </p>

      <!-- Pillar bars -->
      <div id="results-pillars" class="mt-10 space-y-5">
        <!-- filled by JS -->
      </div>

      <!-- Priority recommendations -->
      <div class="mt-12 rounded-2xl border border-ink/10 bg-white p-7">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent">Where to focus first</p>
        <h3 class="mt-2 font-display text-xl font-bold text-deep">Your biggest gaps — and what we'd suggest.</h3>
        <ul id="results-recommendations" class="mt-5 space-y-5 text-base">
          <!-- filled by JS -->
        </ul>
      </div>

      <!-- Primary CTA: build the plan -->
      <div class="mt-12 rounded-2xl border border-deep/20 bg-deep p-8 text-white">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent-soft">Next step</p>
        <h3 class="mt-2 font-display text-2xl font-bold md:text-3xl">
          Ready to close these gaps?
        </h3>
        <p class="mt-3 max-w-2xl text-deep-soft">
          Book a call to talk through what you're seeing. We'll help you prioritize which gaps to fix first and show you what that engagement looks like.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={SCHEDULING_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3 text-base font-semibold text-deep shadow-sm transition hover:bg-accent hover:text-white"
          >
            Book a meeting
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-full border border-white/30 px-7 py-3 text-base font-semibold text-white transition hover:bg-white/10"
          >
            See all services →
          </a>
        </div>
      </div>

      <!-- Optional email upgrade -->
      <div class="mt-12 rounded-2xl border border-ink/10 bg-bg p-7">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent">Optional</p>
        <h3 class="mt-2 font-display text-xl font-bold text-deep">Get the report in your inbox.</h3>
        <p class="mt-2 text-base text-muted">
          Drop your email and we'll send a copy of your results plus a short follow-up note. No newsletter, no drip — just this.
        </p>
        <form
          id="email-results-form"
          action="/api/email-assessment"
          method="POST"
          class="mt-5 flex flex-col gap-3 sm:flex-row"
        >
          <input
            type="email"
            name="email"
            placeholder="you@company.com"
            required
            class="flex-1 rounded-full border border-ink/15 bg-white px-5 py-3 text-base text-ink placeholder:text-muted focus:border-deep focus:outline-none"
          />
          <input type="hidden" name="source" value="pikesquare.co/assessment" />
          <input type="hidden" name="submitted_at" id="email-results-timestamp" value="" />
          <input type="hidden" name="report" id="email-results-payload" value="(no report — user submitted email without completing the assessment)" />
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-deep px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-accent"
          >
            Email me the report
          </button>
        </form>
        <p id="email-results-success" class="mt-4 hidden text-sm font-semibold text-deep">
          <!-- filled by JS -->
        </p>
      </div>
    </div>
  </section>

  <!-- Bottom placeholder section so the closing CTA still works pre-submit -->
  <section id="pre-results-cta">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <p class="text-base text-muted">Prefer to talk to a human first?</p>
      <div class="mt-6 flex justify-center">
        <CTAButton />
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ pillarsJson }}>
  const pillars = JSON.parse(pillarsJson);

  const form = document.getElementById('assessment-form');
  const errorBox = document.getElementById('form-error');
  const results = document.getElementById('results');
  const preResultsCta = document.getElementById('pre-results-cta');
  const headline = document.getElementById('results-headline');
  const summary = document.getElementById('results-summary');
  const pillarsContainer = document.getElementById('results-pillars');
  const recsContainer = document.getElementById('results-recommendations');
  const emailPayload = document.getElementById('email-results-payload');
  const emailForm = document.getElementById('email-results-form');
  const emailSuccess = document.getElementById('email-results-success');

  function maturityBand(avg) {
    if (avg >= 3.5) return { tier: 'Optimized', message: 'Your GTM function is running like a well-oiled machine. You\'re forecasting accurately, reps are hitting quota, and the machine scales. The work now is refinement — getting better at what you already know how to do.' };
    if (avg >= 3.0) return { tier: 'Established', message: 'You\'ve got a solid foundation. The basics are in place, but you\'re not yet predictable. Focus on the one or two weakest pillars — fixing those will unlock the rest.' };
    if (avg >= 2.0) return { tier: 'Developing', message: 'You\'re building, but it\'s still manual and inconsistent. You need to systematize how you work before you can scale. Pick your biggest gap and fix it properly.' };
    return { tier: 'Forming', message: 'You\'re finding your way. That\'s normal early on. The risk is scaling before you have a repeatable motion. Get clarity on strategy and motion before hiring aggressively.' };
  }

  function renderResults(data) {
    // data = [{key, title, current, target, gap, services}, ...]
    const overallCurrent = data.reduce((s, p) => s + p.current, 0) / data.length;
    const overallTarget = data.reduce((s, p) => s + p.target, 0) / data.length;
    const band = maturityBand(overallCurrent);

    headline.textContent = `${band.tier}: ${overallCurrent.toFixed(1)} / 4`;
    summary.textContent = `${band.message} Your target is ${overallTarget.toFixed(1)} / 4. Below is where you have the most work to do.`;

    // Pillar bars
    pillarsContainer.innerHTML = '';
    data.forEach((p) => {
      const currentPct = (p.current / 4) * 100;
      const targetPct = (p.target / 4) * 100;
      const row = document.createElement('div');
      row.className = 'rounded-xl border border-ink/10 bg-white p-5';
      row.innerHTML = `
        <div class="flex items-baseline justify-between gap-4">
          <h4 class="font-display text-base font-bold text-deep">${p.title}</h4>
          <p class="text-sm text-muted">
            <span class="font-semibold text-deep">${p.current}</span>
            <span class="mx-1 text-muted/60">→</span>
            <span class="font-semibold text-accent">${p.target}</span>
            <span class="ml-2 text-xs uppercase tracking-wider">${p.gap > 0 ? `gap ${p.gap}` : 'on target'}</span>
          </p>
        </div>
        <div class="relative mt-3 h-3 w-full rounded-full bg-ink/10">
          <div class="absolute left-0 top-0 h-3 rounded-full bg-accent/30" style="width: ${targetPct}%"></div>
          <div class="absolute left-0 top-0 h-3 rounded-full bg-deep" style="width: ${currentPct}%"></div>
        </div>
      `;
      pillarsContainer.appendChild(row);
    });

    // Top 2 gaps. If everything is on target, fall back to the lowest-current pillars.
    const sorted = [...data].sort((a, b) => b.gap - a.gap || a.current - b.current);
    const topGaps = sorted.slice(0, 2);

    recsContainer.innerHTML = '';
    topGaps.forEach((p, idx) => {
      const li = document.createElement('li');
      li.className = 'rounded-xl border border-ink/10 bg-white p-5';
      const servicesHtml = p.services
        .map((s) => `<a href="${s.href}" class="font-semibold text-deep underline-offset-4 hover:underline">${s.label}</a>`)
        .join('<span class="mx-2 text-muted">•</span>');
      li.innerHTML = `
        <div class="flex items-start gap-3">
          <div class="mt-1 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-accent/10 text-base font-bold text-accent">${idx + 1}</div>
          <div class="flex-1">
            <p class="font-display text-lg font-bold text-deep">${p.title}</p>
            <p class="mt-2 text-sm text-ink">${p.gapImpact}</p>
            <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-muted">Start here:</p>
            <p class="mt-1 text-sm">${servicesHtml}</p>
          </div>
        </div>
      `;
      recsContainer.appendChild(li);
    });

    // Build a plain-text summary the email-results form can submit alongside the email.
    const lines = [
      `Overall current: ${overallCurrent.toFixed(1)} / 4 (${band.tier})`,
      `Overall target: ${overallTarget.toFixed(1)} / 4`,
      '',
      'Per-pillar (current → target, gap):',
      ...data.map((p) => `- ${p.title}: ${p.current} → ${p.target} (gap ${p.gap})`),
      '',
      'Top focus areas:',
      ...topGaps.map((p) => `- ${p.title}`),
    ];
    emailPayload.value = lines.join('\n');

    preResultsCta.classList.add('hidden');
    results.classList.remove('hidden');
    results.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = pillars.map((p) => {
      const cur = form.querySelector(`input[name="${p.key}-current"]:checked`);
      const tgt = form.querySelector(`input[name="${p.key}-target"]:checked`);
      if (!cur || !tgt) return null;
      const current = parseInt(cur.value, 10);
      const target = parseInt(tgt.value, 10);
      return {
        key: p.key,
        title: p.title,
        blurb: p.blurb,
        services: p.services,
        current,
        target,
        gap: Math.max(0, target - current),
      };
    });

    if (data.some((d) => d === null)) {
      errorBox.classList.remove('hidden');
      errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errorBox.classList.add('hidden');
    // Merge in the why and gapImpact from pillar definitions
    const enrichedData = data.map((d) => {
      const pillar = pillars.find((p) => p.key === d.key);
      return { ...d, why: pillar?.why, gapImpact: pillar?.gapImpact };
    });
    renderResults(enrichedData);
  });

  form.addEventListener('reset', () => {
    results.classList.add('hidden');
    preResultsCta.classList.remove('hidden');
    errorBox.classList.add('hidden');
    emailSuccess.classList.add('hidden');
    emailForm.reset();
  });

  function showSubmitMessage(message) {
    emailSuccess.textContent = message;
    emailSuccess.classList.remove('hidden');
  }

  // Submit the email form via fetch so we can show inline confirmation without leaving the results page.
  emailForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const action = emailForm.getAttribute('action') || '';
    // Stamp the submission so the inbox notification shows when it came in.
    const ts = document.getElementById('email-results-timestamp');
    if (ts) ts.value = new Date().toISOString();
    try {
      const fd = new FormData(emailForm);
      const res = await fetch(action, { method: 'POST', body: fd, headers: { Accept: 'application/json' } });
      const body = await res.json().catch(() => ({}));
      if (res.ok && body.ok) {
        showSubmitMessage('Sent — check your inbox in a minute or two.');
        emailForm.reset();
      } else {
        showSubmitMessage(body.error || 'Something went wrong sending the email. Your results are still right above.');
      }
    } catch {
      showSubmitMessage('Couldn\'t reach the email service. Your results are still right above.');
    }
  });
</script>
