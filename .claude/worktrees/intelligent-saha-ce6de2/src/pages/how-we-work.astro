---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';

// Four steps from first call to kickoff. Concrete and time-boxed on purpose —
// "depending on..." is the wrong tone for a firm that promises to ship.
const steps = [
  {
    n: 1,
    title: '30-minute discovery call',
    body: "We listen, you talk. By the end we know whether we're a fit, which engagement shape is right, and the rough size of the work. If we're not the right firm, we'll say so on the call and point you somewhere better.",
  },
  {
    n: 2,
    title: 'Scoped engagement letter — within 7 days',
    body: 'Outcomes, deliverables, weekly cadence, fixed price or fixed retainer. We name the work and the price. No ambiguous "depends on…" clauses. You see exactly what you\'re signing for before you sign.',
  },
  {
    n: 3,
    title: 'Light pre-work and access setup',
    body: 'Async data pull, intros to your team, calendar invites for the operating cadence. We want kickoff to be substantive, not introductions — so we get the small stuff out of the way first.',
  },
  {
    n: 4,
    title: 'Kickoff in 14 days, change in 30',
    body: 'By day 30 you see a measurable change in how GTM runs — not a deck, not a "phase 1." That\'s the bar we hold ourselves to on every engagement, regardless of shape.',
  },
];

// Pricing facts laid out as plain assertions. People skim this section to know
// whether to keep reading.
const pricingPoints = [
  {
    title: 'Diagnostics and projects: fixed scope, fixed price.',
    body: 'You see the price before you sign. Most diagnostics fall in a predictable range — we quote precisely after the discovery call so you can compare apples-to-apples.',
  },
  {
    title: 'Advisory: monthly retainer.',
    body: 'A predictable monthly fee for a defined number of hours and a clear cadence. Cancel any month, no penalty. We\'d rather you re-up because it\'s working than because you\'re trapped.',
  },
  {
    title: 'Fractional leadership: weekly rate, 3–6 month minimum.',
    body: 'Priced as a fraction of a senior operator\'s loaded cost — typically 8 to 20 hours a week. Long enough to ship something, short enough to avoid becoming furniture.',
  },
  {
    title: 'Quick-turn projects: from $1.5k.',
    body: 'Pitch deck refresh, messaging audit, data sheet, tools audit, training module. Async, fixed price, two-day turnaround on the quote.',
  },
  {
    title: 'No success fees, no equity, no platform fees.',
    body: "We're an operator firm, not a sales-tax skim. You pay for senior time and senior thinking — that's it.",
  },
];

// Anti-patterns. Specific is more useful than tasteful here.
const dontDos = [
  {
    title: "We don't write strategy decks and walk.",
    body: "Every engagement includes the operating cadence and behavior change to ship the plan — not a 60-page report you put on a shelf.",
  },
  {
    title: "We don't hand you off to a junior team.",
    body: 'The senior operator who scoped the work runs the work. No analyst layer. No "delivery team" you\'ve never met.',
  },
  {
    title: "We don't lock you into multi-year contracts.",
    body: 'Engagements have a defined scope and end date. If we\'re still useful, you re-engage. If we\'re not, you don\'t.',
  },
  {
    title: "We don't sell platforms or take referral fees.",
    body: "We have no incentive to recommend a tool you don't need. When we say AI is hype for your use case, that's not a sales tactic — it's the actual recommendation.",
  },
  {
    title: "We don't take engagements we can't ship.",
    body: "If a moment is outside our wheelhouse, or the timing isn't right, or the team isn't ready — we'll tell you on the discovery call. We'd rather refer you to the right firm than collect a fee for half-effort work.",
  },
];
---

<BaseLayout title="How We Work — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <h1 class="font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        How a PikeSquare engagement actually runs.
      </h1>
      <p class="mt-6 text-lg text-muted">
        A short version of what to expect from the first call to the last invoice.
      </p>
      <div class="mt-10 flex flex-col items-start gap-4 md:flex-row md:items-center">
        <CTAButton />
        <a
          href="/services"
          class="text-base font-semibold text-deep underline-offset-4 hover:underline"
        >
          See engagement shapes →
        </a>
      </div>
    </div>
  </section>

  <!-- The PikeSquare principle -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">The PikeSquare principle</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        One senior operator owns the strategy <em class="not-italic text-deep">and</em> the execution.
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Most firms either hand you a strategy deck and walk, or send a junior team to execute someone else's plan. Neither works at the speed startups need. PikeSquare engagements are run by someone who has held the seat — CRO, VP Sales, VP CS, head of RevOps — and that same operator scopes the work, writes the plan, runs the weekly cadence, and owns the result.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        No hand-offs. No "delivery team" you've never met. No deliverables that sit on a shelf. The strategy ships because the person who designed it is the one running it.
      </p>
    </div>
  </section>

  <!-- From first call to kickoff -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">From first call to kickoff</p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        Four steps. About two weeks, end-to-end.
      </h2>
      <p class="mt-4 max-w-2xl text-muted">
        Most engagements are running before the third week. We move fast on the front-end so the work has time to compound.
      </p>
      <ol class="mt-12 grid gap-6 md:grid-cols-2">
        {
          steps.map((s) => (
            <li class="rounded-2xl border border-ink/10 bg-white p-7">
              <span class="font-display text-5xl font-bold text-deep/20">0{s.n}</span>
              <h3 class="mt-3 font-display text-xl font-bold text-deep">{s.title}</h3>
              <p class="mt-3 text-muted">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Pricing approach -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Pricing approach</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        Priced to the work, not to a tier.
      </h2>
      <p class="mt-4 max-w-2xl text-muted">
        Five things to know before you book the call.
      </p>
      <ul class="mt-12 space-y-8">
        {
          pricingPoints.map((p) => (
            <li class="flex gap-5">
              <span aria-hidden="true" class="mt-2.5 inline-block h-2.5 w-2.5 flex-none bg-accent" />
              <div>
                <p class="font-display text-lg font-bold text-deep">{p.title}</p>
                <p class="mt-2 text-muted">{p.body}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- What we don't do -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">What we don't do</p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
        The honest no's.
      </h2>
      <p class="mt-4 max-w-2xl text-muted">
        Easier to know whether we're a fit when we're upfront about the things we won't do.
      </p>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          dontDos.map((d) => (
            <article class="flex h-full flex-col rounded-2xl border border-ink/10 bg-white p-6">
              <h3 class="font-display text-lg font-bold text-deep">{d.title}</h3>
              <p class="mt-3 text-muted">{d.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-24 text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-deep md:text-4xl">
        30 minutes. No deck. No commitment.
      </h2>
      <p class="mt-4 text-lg text-muted">
        Tell us where you are. We'll tell you whether we're the right fit — and what shape of engagement makes sense if we are.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row">
        <CTAButton />
        <a
          href="/assessment"
          class="text-base font-semibold text-deep underline-offset-4 hover:underline"
        >
          Or take the free 5-minute assessment first →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
