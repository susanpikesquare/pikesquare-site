---
interface Props {
  title: string;
  href: string;
  blurb: string;
  badge?: string;
}

const { title, href, blurb, badge } = Astro.props;
---

<a
  href={href}
  class="group flex h-full flex-col rounded-2xl border border-ink/10 bg-white p-6 transition hover:border-deep/40 hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-display text-lg font-bold text-deep">{title}</h3>
    {badge && (
      <span class="inline-flex flex-none items-center rounded-full bg-accent px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wider text-white">
        {badge}
      </span>
    )}
  </div>
  <p class="mt-2 text-sm text-muted">{blurb}</p>
  <span class="mt-auto pt-4 text-sm font-semibold text-deep group-hover:underline">
    Read more →
  </span>
</a>
