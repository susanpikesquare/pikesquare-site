---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<BaseLayout title="GTM Diagnostics & Strategy — PikeSquare">
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Service</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        A 4–6 week sprint that produces a defensible GTM plan.
      </h1>
      <p class="mt-6 text-lg text-muted">
        When the board wants the plan, the round is months away, or the current plan no longer holds up — PikeSquare runs a fixed-scope diagnostic and hands you a 90-day operating plan.
      </p>
    </div>
  </section>

  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="rounded-2xl border border-amber-300 bg-amber-50 p-6 text-sm text-ink">
        <p class="font-semibold">TODO for Claude Code</p>
        <p class="mt-2">
          Build out using Section 6.5 of the rewrite plan. Sections: When founders come to us, What's in the diagnostic, Deliverable, How we engage, CTA.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
