---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout title="How We Work — PikeSquare">
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <h1 class="font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        How a PikeSquare engagement actually runs.
      </h1>
      <p class="mt-6 text-lg text-muted">
        A short version of what to expect from the first call to the last invoice.
      </p>
    </div>
  </section>

  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="rounded-2xl border border-amber-300 bg-amber-50 p-6 text-sm text-ink">
        <p class="font-semibold">TODO for Claude Code</p>
        <p class="mt-2">
          Build out using Section 6.7 of the rewrite plan. Sections: The pike square principle, From first call to kickoff (4 steps), Pricing approach, What we don't do.
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
