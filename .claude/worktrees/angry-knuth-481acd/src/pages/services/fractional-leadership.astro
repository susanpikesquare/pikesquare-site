---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<BaseLayout title="Fractional GTM Leadership — PikeSquare">
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Service</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        A senior GTM exec, in seat, without the year-long hire.
      </h1>
      <p class="mt-6 text-lg text-muted">
        PikeSquare embeds an interim CRO, VP Sales, VP CS, or VP Marketing into your company — to own the GTM org while you decide who to hire next.
      </p>
    </div>
  </section>

  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="rounded-2xl border border-amber-300 bg-amber-50 p-6 text-sm text-ink">
        <p class="font-semibold">TODO for Claude Code</p>
        <p class="mt-2">
          Build out the rest of this page using the home page (<code class="rounded bg-white px-1.5 py-0.5">src/pages/index.astro</code>) as a model and Section 6.3 of the rewrite plan in the parent folder.
        </p>
        <p class="mt-2">Pattern to follow:</p>
        <ol class="mt-1 list-decimal pl-5">
          <li>When founders come to us for this (3 trigger situations)</li>
          <li>What we do (5 bullets)</li>
          <li>How we engage (time, duration, pricing, team)</li>
          <li>What changes in the first 30 / 60 / 90 days</li>
          <li>FAQ (3 Q&amp;As)</li>
          <li>CTA</li>
        </ol>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
