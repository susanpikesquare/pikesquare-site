---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
---

<BaseLayout title="Sales Kickoffs & Enablement — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Service</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        A turnkey sales kickoff that actually changes behavior.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        We build and facilitate the whole event. You ship a kickoff your team remembers — content built from your own playbook, exercises that stick, a venue you didn't have to source, and a keynote that lands.
      </p>
      <div class="mt-10">
        <CTAButton label="Talk through your SKO" />
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">What's included</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-deep">
        Built end-to-end.
      </h2>
      <ul class="mt-8 space-y-5">
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">Content turned into training.</p>
            <p class="mt-1 text-muted">We mine your existing decks, plays, and customer stories and turn them into training material that reps can actually use the Monday after.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">Exercises that reinforce the work.</p>
            <p class="mt-1 text-muted">Role-plays, account war-rooms, deal clinics, and team-building tied to the concepts — not generic ice-breakers.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">Venue and logistics.</p>
            <p class="mt-1 text-muted">We book the meeting in a cost-effective way — venue, AV, catering, hotel blocks — and run the production day-of.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">Optional keynote.</p>
            <p class="mt-1 text-muted">Pair the build with a Steve Bamberger keynote (multi-time CRO) on sales excellence, pricing, execution, or GTM motion. <a class="text-deep underline-offset-4 hover:underline" href="/services/keynotes">More on keynotes →</a></p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
      <CTAButton />
    </div>
  </section>
</BaseLayout>
