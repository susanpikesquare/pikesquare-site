---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { SCHEDULING_URL, CONTACT_EMAIL } from '../lib/site';
---

<BaseLayout title="Book a meeting — PikeSquare">
  <!-- Hero -->
  <section class="border-b border-ink/10">
    <div class="mx-auto max-w-3xl px-6 pb-16 pt-20 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Book a meeting</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-deep md:text-5xl">
        30 minutes. No deck.
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-muted">
        Tell us where you are. We'll listen, ask questions, and by the end of the call you'll have a clear answer on whether — and how — we can help.
      </p>
      <div class="mt-10 flex justify-center">
        <CTAButton label="See available times →" />
      </div>
      <p class="mt-4 text-sm text-muted">
        Opens our scheduler in a new tab.
      </p>
    </div>
  </section>

  <!-- What to expect -->
  <section class="border-b border-ink/10 bg-white">
    <div class="mx-auto max-w-3xl px-6 py-16">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">What to expect</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-deep">
        A useful 30 minutes — even if we don't end up working together.
      </h2>
      <ul class="mt-8 space-y-5">
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">You talk first.</p>
            <p class="mt-1 text-muted">Walk us through the moment — the deal, the team, the quarter, the board ask. We'll listen and ask sharp questions.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">We tell you what we'd actually do.</p>
            <p class="mt-1 text-muted">Where we'd start, what shape of engagement fits, and a rough sense of cost and timing.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span aria-hidden="true" class="mt-2 inline-block h-2.5 w-2.5 flex-none bg-accent"></span>
          <div>
            <p class="font-semibold text-ink">If we're not the fit, we'll tell you.</p>
            <p class="mt-1 text-muted">And where possible, point you at the operator, advisor, or firm who is. We'd rather lose a deal than ship one that won't work.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Alt contact -->
  <section>
    <div class="mx-auto max-w-3xl px-6 py-16 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Prefer email?</p>
      <p class="mt-3 text-lg text-ink">
        Reach us at
        <a href={`mailto:${CONTACT_EMAIL}`} class="font-semibold text-deep underline-offset-4 hover:underline">{CONTACT_EMAIL}</a>.
      </p>
      <div class="mt-10 flex justify-center">
        <CTAButton label="Or grab a time on the calendar →" />
      </div>
    </div>
  </section>
</BaseLayout>
